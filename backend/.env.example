# PRAXIO Portal Access
PRAXIO_BASE_URL=https://portaldocliente.praxio.com.br
PRAXIO_USERNAME=
PRAXIO_PASSWORD=

# Database
DATABASE_URL=sqlite+aiosqlite:///./prax.db

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Server
HOST=0.0.0.0
PORT=8000

# SLA Defaults (hours)
SLA_WARNING_HOURS=24
SLA_CRITICAL_HOURS=8
SLA_OVERDUE_HOURS=0

# App
DEBUG=false
